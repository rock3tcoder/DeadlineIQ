# =============================================================================
# DeadlineIQ — Environment Variables
# Copy this file to .env.local and fill in every value before running the app.
# NEVER commit .env.local to git.
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE
# Where to get: https://supabase.com → New project → Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Note: SERVICE_ROLE_KEY is secret — never prefix it with NEXT_PUBLIC_

# -----------------------------------------------------------------------------
# STRIPE
# Where to get: https://dashboard.stripe.com → Developers → API keys
# Use test keys (pk_test_ / sk_test_) during development
# -----------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_SECRET_KEY=sk_test_your-secret-key
# Where to get webhook secret: Stripe Dashboard → Webhooks → Add endpoint → signing secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
# Create products/prices in Stripe Dashboard → Products, then copy the price IDs:
STRIPE_PRICE_STARTER=price_your-starter-price-id
STRIPE_PRICE_PRO=price_your-pro-price-id
STRIPE_PRICE_BUSINESS=price_your-business-price-id

# -----------------------------------------------------------------------------
# RESEND (transactional email)
# Where to get: https://resend.com → API Keys → Create API Key
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=alerts@deadlineiq.com
# Verify your sending domain in Resend Dashboard → Domains

# -----------------------------------------------------------------------------
# OPENAI
# Where to get: https://platform.openai.com → API Keys → Create new secret key
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key

# -----------------------------------------------------------------------------
# SENTRY (error monitoring)
# Where to get: https://sentry.io → New Project → Next.js → DSN
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=https://your-key@o0.ingest.sentry.io/your-project-id
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=hostwatch
SENTRY_AUTH_TOKEN=your-sentry-auth-token
# Sentry Auth Token: sentry.io → Settings → Auth Tokens → Create New Token

# -----------------------------------------------------------------------------
# APP CONFIG
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3003
NEXT_PUBLIC_SITE_URL=http://localhost:3003
# In production, set both to: https://deadlineiq.com

# Admin page password (Phase 12) — pick any strong password
ADMIN_PASSWORD=your-strong-admin-password

# -----------------------------------------------------------------------------
# SCRAPER (used in /scraper — deployed to Railway)
# These same Supabase keys go in Railway environment variables too
# -----------------------------------------------------------------------------
# SUPABASE_URL=        (same as NEXT_PUBLIC_SUPABASE_URL)
# SUPABASE_SERVICE_ROLE_KEY= (same as above)
# OPENAI_API_KEY=      (same as above)
# RESEND_API_KEY=      (same as above)
